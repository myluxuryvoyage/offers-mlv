<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MLV — Road Trip</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
    :root { --navy: #1C2E4A; --gold: #C9A96E; --gold2: #B8944F; --white: #fff; --cream: #F8F6F1; --gray: #666; --light: #F2F0EC; --red: #C0392B; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #E5E3DE; font-family: 'Montserrat', sans-serif; color: var(--navy); }
    .doc { max-width: 900px; margin: 0 auto; background: var(--white); box-shadow: 0 4px 40px rgba(0, 0, 0, .15); }
    .cover { position: relative; height: 82vh; min-height: 520px; max-height: 840px; overflow: hidden; display: flex; flex-direction: column; }
    .cover-bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(.48); background-image: url('{{photo_cover}}'); }
    .cover-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(28, 46, 74, .05) 0%, rgba(28, 46, 74, .62) 100%); }
    .cover-body { position: relative; z-index: 2; flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 24px; text-align: center; }
    .mlv-logo { height: 48px; filter: brightness(0) invert(1); opacity: .88; margin-bottom: 32px; }
    .cover-label { font-size: 9px; letter-spacing: .4em; color: var(--gold); text-transform: uppercase; margin-bottom: 16px; }
    .cover-title { font-family: 'Playfair Display', serif; font-size: clamp(44px, 7vw, 76px); font-weight: 700; color: #fff; letter-spacing: .04em; text-transform: uppercase; line-height: 1.05; margin-bottom: 10px; }
    .cover-divider { width: 56px; height: 1px; background: var(--gold); margin: 16px auto; }
    .cover-route { font-size: 14px; font-weight: 500; color: #fff; letter-spacing: .06em; margin-bottom: 8px; }
    .cover-dates { font-size: 11px; color: rgba(255, 255, 255, .6); letter-spacing: .14em; text-transform: uppercase; }
    .cover-foot { position: relative; z-index: 2; background: var(--cream); padding: 18px 32px; display: flex; align-items: center; justify-content: center; border-top: 3px solid var(--gold); }
    .cover-foot-logo { height: 46px; }
    .overview { background: var(--navy); display: grid; grid-template-columns: repeat(4, 1fr); }
    .ov-item { padding: 20px 12px; text-align: center; border-right: 1px solid rgba(255, 255, 255, .1); }
    .ov-item:last-child { border-right: none; }
    .ov-label { font-size: 8px; letter-spacing: .22em; color: var(--gold); text-transform: uppercase; margin-bottom: 5px; }
    .ov-val { font-size: 12px; font-weight: 500; color: #fff; line-height: 1.3; }
    .day-block { border-bottom: 2px solid rgba(201, 169, 110, .25); }
    .day-header { padding: 30px 44px 20px; }
    .day-eye { font-size: 9px; letter-spacing: .3em; color: var(--gold); text-transform: uppercase; margin-bottom: 6px; }
    .day-title { font-family: 'Playfair Display', serif; font-size: clamp(22px, 3.5vw, 34px); font-weight: 700; color: var(--navy); letter-spacing: .04em; text-transform: uppercase; }
    .events { padding: 0 44px 32px; }
    .event { display: flex; padding: 26px 0 0; }
    .ev-tl { width: 24px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; padding-top: 5px; }
    .ev-dot { width: 9px; height: 9px; border: 2px solid var(--gold); border-radius: 50%; background: #fff; flex-shrink: 0; z-index: 2; }
    .ev-line { width: 1px; flex: 1; min-height: 22px; margin-top: 4px; background: repeating-linear-gradient(to bottom, var(--gold) 0, var(--gold) 4px, transparent 4px, transparent 9px); }
    .ev-photo { width: 160px; min-width: 160px; height: 122px; object-fit: cover; border-radius: 2px; margin: 0 18px 0 10px; flex-shrink: 0; }
    .ev-content { flex: 1; padding-top: 2px; }
    .ev-time { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 3px; }
    .ev-name { font-size: 13px; color: var(--navy); line-height: 1.35; }
    .ev-name .hl { color: var(--gold); font-weight: 700; }
    .ev-desc { font-size: 12px; font-style: italic; color: var(--gray); margin-top: 7px; line-height: 1.6; }
    .hotel-card { margin: 0 44px 28px; background: var(--cream); border-left: 3px solid var(--gold); padding: 14px 18px; display: flex; align-items: center; gap: 14px; }
    .hc-name { font-size: 13px; font-weight: 700; color: var(--navy); }
    .hc-photo { width: 68px; height: 50px; object-fit: cover; border-radius: 2px; margin-left: auto; flex-shrink: 0; }
    .vehicles-separator { background: var(--navy); padding: 40px 24px; text-align: center; }
    .vs-title { font-family: 'Playfair Display', serif; font-size: clamp(18px, 3vw, 30px); font-weight: 700; color: #fff; text-transform: uppercase; }
    .vs-sub { font-size: 10px; letter-spacing: .18em; color: var(--gold); text-transform: uppercase; }
    .cars-wrap { padding: 32px 44px; }
    .car-card { border: 1px solid rgba(201, 169, 110, .28); margin-bottom: 28px; }
    .car-slider-wrap { position: relative; height: 280px; overflow: hidden; }
    .car-slide { width: 100%; height: 100%; background-size: cover; background-position: center; }
    .car-body { padding: 22px 26px 28px; }
    .car-name { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: var(--navy); }
    .car-price-box { background: var(--navy); padding: 18px 22px; display: flex; justify-content: space-between; margin-bottom: 20px; }
    .cp-label { font-size: 8px; color: rgba(255, 255, 255, 0.5); text-transform: uppercase; }
    .cp-val { font-size: 13px; color: #fff; font-weight: 600; }
    .cta { padding: 44px; text-align: center; background: var(--cream); }
    .btn-wa { background: #25D366; color: #fff; padding: 13px 28px; text-decoration: none; font-size: 10px; font-weight: 600; text-transform: uppercase; display: inline-flex; align-items: center; gap: 10px; }
    @media (max-width: 620px) { .overview { grid-template-columns: repeat(2, 1fr); } .ev-photo { width: 100px; height: 86px; } }
    </style>
</head>
<body>
    <div class="doc">
        <div class="cover">
            <div class="cover-bg"></div>
            <div class="cover-overlay"></div>
            <div class="cover-body">
                <img class="mlv-logo" src="https://myluxuryvoyage.com/wp-content/uploads/2023/09/MLV-logo-white-menu.png">
                <div class="cover-label">{{rt_label}}</div>
                <div class="cover-title">{{rt_title_line1}}<br>{{rt_title_line2}}</div>
                <div class="cover-divider"></div>
                <div class="cover-route">{{rt_route}}</div>
                <div class="cover-dates">{{rt_dates}} · {{rt_duration}}</div>
            </div>
            <div class="cover-foot">
                <img class="cover-foot-logo" src="https://myluxuryvoyage.com/wp-content/uploads/2025/02/MLV-logo-white-1024x724.png">
            </div>
        </div>

        <div class="overview">
            <div class="ov-item"><div class="ov-label">Route</div><div class="ov-val">{{rt_route_short}}</div></div>
            <div class="ov-item"><div class="ov-label">Dates</div><div class="ov-val">{{rt_dates_short}}</div></div>
            <div class="ov-item"><div class="ov-label">Durée</div><div class="ov-val">{{rt_duration}}</div></div>
            <div class="ov-item"><div class="ov-label">Pays</div><div class="ov-val">{{rt_countries}}</div></div>
        </div>

        <div id="itinerary-content">
            {{itinerary_html}}
        </div>

        <div class="vehicles-separator">
            <div class="vs-title">{{vs_title}}</div>
            <div class="vs-sub">{{vs_sub}}</div>
        </div>

        <div class="cars-wrap">
            {{cars_html}}
        </div>

        <div class="cta">
            <p>{{cta_text}}</p>
            <a class="btn-wa" href="{{whatsapp_link}}">
                <svg class="wa-svg" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.539 2.016 2.126-.54c1.029.563 2.025.921 3.162.921l.001.001c3.181 0 5.768-2.586 5.768-5.766 0-3.18-2.587-5.765-5.769-5.765zm3.425 8.127c-.142.399-.713.731-1.124.814-.29.058-.669.103-1.648-.282-1.25-.491-2.031-1.743-2.093-1.826-.062-.083-.505-.672-.505-1.284 0-.612.316-.913.442-1.036.126-.123.273-.154.364-.154h.243c.091 0 .212.001.319.255.109.258.375.913.408.98.033.067.054.145.011.233-.042.088-.063.142-.126.216-.063.074-.131.165-.187.221-.063.064-.128.134-.055.258.073.123.325.535.697.865.48.425.883.557 1.006.619.123.062.194.052.265-.031.071-.083.305-.355.387-.476.082-.122.164-.103.276-.062.112.041.713.336.836.398.123.062.205.093.236.145.031.052.031.305-.111.704zM12 2C6.477 2 2 6.477 2 12c0 2.136.67 4.113 1.812 5.736L2.347 23.26l5.704-1.422C9.522 22.564 10.72 23 12 23c5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>
                Discuter sur WhatsApp
            </a>
        </div>
    </div>
</body>
</html>
