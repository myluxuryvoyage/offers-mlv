<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Luxury Voyage — Sélection de chambres</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
    :root { --navy: #1C2E4A; --gold: #C9A96E; --gold2: #B8944F; --white: #fff; --cream: #F8F6F1; --gray: #666; --light: #F2F0EC; --green: #1A6B3C; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #E5E3DE; font-family: 'Montserrat', sans-serif; color: var(--navy); }
    .doc { max-width: 900px; margin: 0 auto; background: var(--white); box-shadow: 0 4px 40px rgba(0, 0, 0, .15); }
    .lang-bar { position: fixed; top: 0; right: 0; z-index: 200; display: flex; background: rgba(28, 46, 74, .9); backdrop-filter: blur(8px); border-bottom-left-radius: 8px; }
    .lang-btn { padding: 8px 14px; background: transparent; border: none; color: rgba(255, 255, 255, .5); cursor: pointer; font-size: 10px; letter-spacing: .1em; font-family: 'Montserrat', sans-serif; transition: color .2s; }
    .lang-btn.active, .lang-btn:hover { color: var(--gold); }
    .hero { position: relative; height: 62vh; min-height: 420px; max-height: 700px; overflow: hidden; }
    .hero-slider { position: absolute; inset: 0; display: flex; transition: transform .6s ease; }
    .hero-slide { min-width: 100%; height: 100%; background-size: cover; background-position: center; filter: brightness(.46); }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(28, 46, 74, .05) 0%, rgba(28, 46, 74, .68) 100%); }
    .hero-mlv-logo { position: absolute; top: 28px; left: 50%; transform: translateX(-50%); height: 48px; filter: brightness(0) invert(1); opacity: .9; z-index: 10; }
    .hero-content { position: absolute; bottom: 46px; left: 0; right: 0; text-align: center; padding: 0 24px; }
    .hero-eyebrow { font-size: 9px; letter-spacing: .4em; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; }
    .hero-title { font-family: 'Playfair Display', serif; font-size: clamp(26px, 4.5vw, 50px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: 8px; }
    .hero-title em { font-style: italic; font-weight: 400; color: var(--gold); }
    .hero-sub { font-size: 11px; color: rgba(255, 255, 255, .6); letter-spacing: .14em; text-transform: uppercase; }
    .slider-dots { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); display: flex; gap: 7px; z-index: 10; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, .38); cursor: pointer; transition: background .2s; }
    .dot.active { background: var(--gold); }
    .slider-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(0, 0, 0, .3); border: none; color: #fff; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; z-index: 10; transition: background .2s; }
    .slider-btn:hover { background: rgba(0, 0, 0, .55); }
    .slider-prev { left: 16px; } .slider-next { right: 16px; }
    .hero-strip { background: var(--cream); padding: 14px 32px; border-top: 3px solid var(--gold); }
    .sum-bar { background: var(--navy); display: grid; grid-template-columns: repeat(5, 1fr); }
    .sb-item { padding: 18px 12px; text-align: center; border-right: 1px solid rgba(255, 255, 255, .1); }
    .sb-item:last-child { border-right: none; }
    .sb-label { font-size: 8px; letter-spacing: .2em; color: var(--gold); text-transform: uppercase; margin-bottom: 4px; }
    .sb-val { font-size: 11px; font-weight: 500; color: #fff; line-height: 1.3; }
    .intro { padding: 32px 44px 8px; }
    .intro-eye { font-size: 9px; letter-spacing: .32em; color: var(--gold); text-transform: uppercase; margin-bottom: 7px; }
    .intro-title { font-family: 'Playfair Display', serif; font-size: clamp(20px, 3vw, 26px); font-weight: 700; color: var(--navy); margin-bottom: 10px; }
    .intro-text { font-size: 13px; color: var(--gray); line-height: 1.75; }
    .rooms { padding: 24px 44px; }
    .room-card { border: 1px solid rgba(201, 169, 110, .25); margin-bottom: 24px; position: relative; transition: box-shadow .2s, border-color .2s; }
    .room-card:hover { box-shadow: 0 4px 24px rgba(201, 169, 110, .18); border-color: rgba(201, 169, 110, .5); }
    .room-card.selected { border: 2px solid var(--gold); box-shadow: 0 4px 28px rgba(201, 169, 110, .22); }
    .selected-badge { display: none; position: absolute; top: -1px; right: -1px; background: var(--gold); color: var(--navy); font-size: 9px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; padding: 5px 14px; z-index: 5; }
    .room-card.selected .selected-badge { display: block; }
    .room-media { position: relative; height: 270px; overflow: hidden; }
    .room-slider { display: flex; height: 100%; transition: transform .5s ease; }
    .room-slide { min-width: 100%; height: 100%; background-size: cover; background-position: center; }
    .room-dots { position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%); display: flex; gap: 5px; }
    .rdot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255, 255, 255, .4); cursor: pointer; transition: background .2s; }
    .rdot.active { background: var(--gold); }
    .room-prev, .room-next { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(0, 0, 0, .35); border: none; color: #fff; width: 34px; height: 34px; border-radius: 50%; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; z-index: 5; transition: background .2s; }
    .room-prev { left: 12px; } .room-next { right: 12px; }
    .room-body { padding: 22px 26px; }
    .room-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
    .room-name { font-family: 'Playfair Display', serif; font-size: clamp(17px, 2.5vw, 22px); font-weight: 700; color: var(--navy); }
    .room-type { font-size: 11px; font-style: italic; color: var(--gray); margin-top: 3px; }
    .room-price { text-align: right; flex-shrink: 0; }
    .room-price-night { font-size: 11px; color: var(--gray); margin-bottom: 2px; }
    .room-price-total { font-family: 'Playfair Display', serif; font-size: clamp(20px, 2.8vw, 26px); font-weight: 700; color: var(--gold); }
    .room-specs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
    .spec-tag { background: var(--light); border: 1px solid rgba(201, 169, 110, .2); padding: 4px 10px; font-size: 10px; color: var(--navy); letter-spacing: .04em; }
    .room-desc { font-size: 12px; color: var(--gray); line-height: 1.65; margin-bottom: 16px; }
    .room-svcs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px; }
    .svc-pill { background: var(--cream); padding: 4px 10px; font-size: 10px; color: var(--navy); border-radius: 20px; display: flex; align-items: center; gap: 5px; }
    .svc-pill-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
    .room-footer { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 14px; border-top: 1px solid rgba(201, 169, 110, .18); }
    .room-conds { font-size: 11px; color: var(--gray); font-style: italic; }
    .btn-select { background: var(--navy); color: #fff; border: none; padding: 11px 26px; font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; cursor: pointer; border-radius: 1px; transition: background .2s; }
    .btn-select:hover { background: var(--gold); }
    .room-card.selected .btn-select { background: var(--green); }
    .section { padding: 28px 44px; border-top: 1px solid rgba(201, 169, 110, .15); }
    .sec-eye { font-size: 9px; letter-spacing: .32em; color: var(--gold); text-transform: uppercase; margin-bottom: 7px; }
    .sec-title { font-family: 'Playfair Display', serif; font-size: clamp(18px, 2.5vw, 24px); font-weight: 700; color: var(--navy); margin-bottom: 16px; }
    .cond-block { background: var(--light); border-left: 2px solid var(--gold); padding: 14px 18px; margin-bottom: 10px; }
    .cond-title { font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--navy); margin-bottom: 5px; }
    .cond-text { font-size: 12px; color: var(--gray); line-height: 1.65; }
    .cta { padding: 48px 44px; text-align: center; background: var(--cream); }
    .cta-selected { display: none; background: var(--navy); color: #fff; padding: 14px 24px; margin-bottom: 22px; font-size: 13px; border-radius: 1px; }
    .cta-room-name { color: var(--gold); font-weight: 600; }
    .cta-text { font-size: 13px; color: var(--gray); line-height: 1.8; max-width: 500px; margin: 0 auto 26px; }
    .btn-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-accept { background: var(--gold); color: var(--navy); border: none; padding: 15px 40px; font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; cursor: pointer; border-radius: 1px; transition: all .2s; }
    .btn-accept:hover { background: var(--gold2); transform: translateY(-2px); }
    .btn-accept:disabled { background: #ccc; color: #999; cursor: not-allowed; transform: none; }
    .btn-wa { display: inline-flex; align-items: center; gap: 10px; background: transparent; color: var(--navy); border: 1.5px solid var(--navy); padding: 14px 28px; font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; text-decoration: none; border-radius: 1px; transition: all .2s; }
    .btn-wa:hover { background: var(--navy); color: #fff; transform: translateY(-2px); }
    .wa-svg { width: 15px; height: 15px; fill: currentColor; }
    .modal-bg { display: none; position: fixed; inset: 0; background: rgba(0, 0, 0, .78); z-index: 300; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .modal-bg.open { display: flex; }
    .modal { background: #fff; border-top: 3px solid var(--gold); padding: 44px; max-width: 440px; width: 90%; border-radius: 2px; text-align: center; }
    .modal-icon { font-size: 32px; margin-bottom: 12px; }
    .modal-title { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--navy); margin-bottom: 8px; }
    .modal-sel { font-size: 13px; color: var(--gold); font-weight: 600; margin-bottom: 12px; }
    .modal-body { font-size: 12px; color: var(--gray); line-height: 1.75; margin-bottom: 28px; }
    .modal-close { background: transparent; border: 1px solid #ddd; color: var(--gray); padding: 10px 26px; font-family: 'Montserrat', sans-serif; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; cursor: pointer; border-radius: 1px; transition: all .2s; }
    .doc-footer { background: var(--navy); padding: 22px 44px; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
    .footer-logo { height: 30px; filter: brightness(0) invert(1); opacity: .65; }
    .footer-txt { font-size: 10px; color: rgba(255, 255, 255, .38); letter-spacing: .06em; line-height: 1.7; text-align: right; }
    @media (max-width: 620px) { .sum-bar { grid-template-columns: repeat(3, 1fr); } .rooms, .intro, .section, .cta { padding: 24px 20px; } .room-header { flex-direction: column; } .room-price { text-align: left; } .doc-footer { padding: 20px; flex-direction: column; text-align: center; } .footer-txt { text-align: center; } .room-footer { flex-direction: column; align-items: stretch; } }
    </style>
</head>
<body>
    <div class="lang-bar">
        <button class="lang-btn active" onclick="setLang('fr')">FR</button>
        <button class="lang-btn" onclick="setLang('en')">EN</button>
        <button class="lang-btn" onclick="setLang('ar')">AR</button>
    </div>

    <div class="doc">
        <div class="hero">
            <div class="hero-slider" id="slider">
                <div class="hero-slide" style="background-image:url('{{photo_hero_1}}')"></div>
                <div class="hero-slide" style="background-image:url('{{photo_hero_2}}')"></div>
                <div class="hero-slide" style="background-image:url('{{photo_hero_3}}')"></div>
            </div>
            <div class="hero-overlay"></div>
            <img class="hero-mlv-logo" src="https://myluxuryvoyage.com/wp-content/uploads/2023/09/MLV-logo-white-menu.png">
            <div class="hero-content">
                <div class="hero-eyebrow">{{h-eye}}</div>
                <div class="hero-title">{{hotel_name}}<br><em>{{h-title-em}}</em></div>
                <div class="hero-sub">{{location}} · {{dates}} · {{nights_count}}</div>
            </div>
        </div>
        <div class="hero-strip"></div>

        <div class="sum-bar">
            <div class="sb-item"><div class="sb-label">Hôtel</div><div class="sb-val">{{hotel_name}}</div></div>
            <div class="sb-item"><div class="sb-label">Arrivée</div><div class="sb-val">{{check_in}}</div></div>
            <div class="sb-item"><div class="sb-label">Départ</div><div class="sb-val">{{check_out}}</div></div>
            <div class="sb-item"><div class="sb-label">Nuits</div><div class="sb-val">{{nights_count}}</div></div>
            <div class="sb-item"><div class="sb-label">Voyageurs</div><div class="sb-val">{{travelers}}</div></div>
        </div>

        <div class="intro">
            <div class="intro-eye">{{i-eye}}</div>
            <div class="intro-title">{{i-title}}</div>
            <div class="intro-text">{{i-text}}</div>
        </div>

        <div class="rooms">
            <div class="room-card" id="card-1">
                <div class="selected-badge">✓ Sélectionnée</div>
                <div class="room-media">
                    <div class="room-slider" id="rs-1">
                        <div class="room-slide" style="background-image:url('{{r1_photo_1}}')"></div>
                        <div class="room-slide" style="background-image:url('{{r1_photo_2}}')"></div>
                    </div>
                    <button class="room-prev" onclick="rSlide(1,-1)">‹</button>
                    <button class="room-next" onclick="rSlide(1,1)">›</button>
                    <div class="room-dots" id="rd-1"></div>
                </div>
                <div class="room-body">
                    <div class="room-header">
                        <div>
                            <div class="room-name">{{r1_name}}</div>
                            <div class="room-type">{{r1_type}}</div>
                        </div>
                        <div class="room-price">
                            <div class="room-price-night">à partir de</div>
                            <div class="room-price-total">{{r1_price}}</div>
                            <div class="room-price-night">pour {{nights_count}}</div>
                        </div>
                    </div>
                    <div class="room-desc">{{r1_desc}}</div>
                    <div class="room-footer">
                        <div class="room-conds">{{r1_cond}}</div>
                        <button class="btn-select" onclick="selectRoom(1,'{{r1_name}}','{{r1_price}}')">Choisir cette chambre</button>
                    </div>
                </div>
            </div>

            <div class="room-card" id="card-2">
                <div class="selected-badge">✓ Sélectionnée</div>
                <div class="room-media">
                    <div class="room-slider" id="rs-2">
                        <div class="room-slide" style="background-image:url('{{r2_photo_1}}')"></div>
                        <div class="room-slide" style="background-image:url('{{r2_photo_2}}')"></div>
                    </div>
                    <button class="room-prev" onclick="rSlide(2,-1)">‹</button>
                    <button class="room-next" onclick="rSlide(2,1)">›</button>
                    <div class="room-dots" id="rd-2"></div>
                </div>
                <div class="room-body">
                    <div class="room-header">
                        <div>
                            <div class="room-name">{{r2_name}}</div>
                            <div class="room-type">{{r2_type}}</div>
                        </div>
                        <div class="room-price">
                            <div class="room-price-night">à partir de</div>
                            <div class="room-price-total">{{r2_price}}</div>
                            <div class="room-price-night">pour {{nights_count}}</div>
                        </div>
                    </div>
                    <div class="room-desc">{{r2_desc}}</div>
                    <div class="room-footer">
                        <div class="room-conds">{{r2_cond}}</div>
                        <button class="btn-select" onclick="selectRoom(2,'{{r2_name}}','{{r2_price}}')">Choisir cette chambre</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="cta">
            <div class="cta-selected" id="cta-sel">Sélection : <span class="cta-room-name" id="sel-name">...</span> — <span id="sel-price">...</span></div>
            <p class="cta-text">{{cta_text}}</p>
            <div class="btn-row">
                <button class="btn-accept" id="btn-submit" onclick="openModal()" disabled>✓ Confirmer mon choix</button>
                <a class="btn-wa" href="{{whatsapp_link}}">Nous contacter</a>
            </div>
        </div>
    </div>

    <div class="modal-bg" id="modal">
        <div class="modal">
            <div class="modal-icon">✦</div>
            <div class="modal-title">Merci pour votre choix</div>
            <div class="modal-sel" id="modal-sel-txt"></div>
            <div class="modal-body">Un conseiller vous contactera pour finaliser la réservation.</div>
            <button class="modal-close" onclick="closeModal()">Fermer</button>
        </div>
    </div>

    <script>
        let selectedId = null;
        function selectRoom(id, name, price) {
            document.querySelectorAll('.room-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('card-' + id).classList.add('selected');
            selectedId = id;
            document.getElementById('cta-sel').style.display = 'block';
            document.getElementById('sel-name').textContent = name;
            document.getElementById('sel-price').textContent = price;
            document.getElementById('btn-submit').disabled = false;
        }
        function openModal() {
            document.getElementById('modal-sel-txt').textContent = document.getElementById('sel-name').textContent;
            document.getElementById('modal').classList.add('open');
        }
        function closeModal() { document.getElementById('modal').classList.remove('open'); }
        
        // Sliders
        let cur = 0;
        function slide(dir) {
            const s = document.querySelectorAll('.hero-slide');
            cur = (cur + dir + s.length) % s.length;
            document.getElementById('slider').style.transform = `translateX(-${cur * 100}%)`;
        }
        function rSlide(rid, dir) {
            const s = document.querySelectorAll(`#rs-${rid} .room-slide`);
            let rCur = 0; // Simplifié pour le template
            document.getElementById(`rs-${rid}`).style.transform = `translateX(-${(dir > 0 ? 1 : 0) * 100}%)`;
        }
    </script>
</body>
</html>
